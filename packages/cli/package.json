{
  "name": "@db-migrate-ts/cli",
  "version": "1.0.0",
  "description": "CLI for db-migrate-ts — type-safe database migrations",
  "license": "MIT",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "db-migrate-ts": "./dist/cli.js"
  },
