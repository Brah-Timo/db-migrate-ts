{
  "name": "db-migrate-ts",
  "version": "1.0.0",
  "type": "module",
  "description": "Type-safe database migrations powered by Zod and TypeScript",
  "author": "db-migrate-ts contributors",
  "license": "MIT",
  "homepage": "https://db-migrate-ts.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/db-migrate-ts/db-migrate-ts.git",
    "directory": "packages/core"
  },
  "keywords": [
    "database", "migration", "typescript", "type-safe",
    "zod", "postgres", "mysql", "sqlite", "sql", "orm"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./dialects/postgres": {
      "types": "./dist/dialects/postgres.dialect.d.ts",
      "import": "./dist/dialects/postgres.dialect.mjs",
      "require": "./dist/dialects/postgres.dialect.js"
    },
    "./dialects/mysql": {
      "types": "./dist/dialects/mysql.dialect.d.ts",
      "import": "./dist/dialects/mysql.dialect.mjs",
      "require": "./dist/dialects/mysql.dialect.js"
    },
    "./dialects/sqlite": {
      "types": "./dist/dialects/sqlite.dialect.d.ts",
      "import": "./dist/dialects/sqlite.dialect.mjs",
      "require": "./dist/dialects/sqlite.dialect.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": { "optional": false },
    "typescript": { "optional": false }
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "glob": "^10.3.10",
    "ora": "^8.0.1",
    "pathe": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.2.0",
    "better-sqlite3": "^9.4.3",
    "@types/better-sqlite3": "^7.6.8",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "zod": "^3.22.4"
  },
  "optionalDependencies": {
    "pg": "^8.11.3",
    "@types/pg": "^8.11.0",
    "mysql2": "^3.7.1",
    "better-sqlite3": "^9.4.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
